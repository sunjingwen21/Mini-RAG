MINI_RAG_ADMIN_TOKEN=change-this-to-a-long-random-token
MINI_RAG_DEBUG=false
MINI_RAG_CORS_ORIGINS=https://your-domain.example
MINI_RAG_AUTH_FAILURE_WINDOW_SECONDS=300
MINI_RAG_AUTH_MAX_FAILURES=8
MINI_RAG_AUTH_BLOCK_SECONDS=900

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS_CONTEXT=1200
LLM_MAX_TOKENS_FALLBACK=800

MINI_RAG_LOG_LEVEL=INFO
